# Snyk ポリシーファイル（例外の受容記録）
# 運用ルール: 例外は必ず reason（理由）と expires（期限）を明記し、期限切れ時に再判断する。
# 統括承認: 2026-07-21（コーディネーター経由）
#
# 背景: next は 14.2 系最新（14.2.35。Critical の認可バイパスは解消済み）まで更新済み。
# 以下の high は修正版が next 15.5.x 以降にしか存在せず、メジャー更新は進行中の
# サインイン修正作業（未コミット）と競合するため、別タスク（next 15 系への更新）で
# 対応するまで期限付きで受容する。
version: v1.5.0
ignore:
  SNYK-JS-NEXT-16638674:
    - '*':
        reason: 'next 14.2 系に修正なし（fix は 15.5.x）。next 15 更新の別タスクで解消予定。'
        expires: 2027-01-21T00:00:00.000Z
  SNYK-JS-NEXT-16638680:
    - '*':
        reason: 'next 14.2 系に修正なし（fix は 15.5.x）。next 15 更新の別タスクで解消予定。'
        expires: 2027-01-21T00:00:00.000Z
  SNYK-JS-NEXT-16638682:
    - '*':
        reason: 'next 14.2 系に修正なし（fix は 15.5.x）。next 15 更新の別タスクで解消予定。'
        expires: 2027-01-21T00:00:00.000Z
  SNYK-JS-NEXT-16638683:
    - '*':
        reason: 'next 14.2 系に修正なし（fix は 15.5.x）。next 15 更新の別タスクで解消予定。'
        expires: 2027-01-21T00:00:00.000Z
  SNYK-JS-NEXT-15954202:
    - '*':
        reason: 'next 14.2 系に修正なし（fix は 15.5.x）。next 15 更新の別タスクで解消予定。'
        expires: 2027-01-21T00:00:00.000Z
  SNYK-JS-NEXT-15104645:
    - '*':
        reason: 'next 14.2 系に修正なし（fix は 15.5.x）。next 15 更新の別タスクで解消予定。'
        expires: 2027-01-21T00:00:00.000Z
  SNYK-JS-NEXT-15921797:
    - '*':
        reason: 'next 14.2 系に修正なし（fix は 15.5.x）。next 15 更新の別タスクで解消予定。'
        expires: 2027-01-21T00:00:00.000Z
  SNYK-JS-WS-17988732:
    - '*':
        reason: 'ws は next の WebSocket 経路の間接依存で直接更新経路なし。next 15 更新の別タスクで解消予定。'
        expires: 2027-01-21T00:00:00.000Z

# Snyk のスキャン対象から除外するパス（秘匿値・生成物・依存物・スキャン用 venv）。
exclude:
  global:
    - "**/.env*"
    - "**/cloud.env"
    - "frontend/out/**"
    - "**/node_modules/**"
    - "**/.venv*/**"
