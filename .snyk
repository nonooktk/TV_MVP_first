# Snyk ポリシーファイル（例外の受容記録）
# 運用ルール: 例外は必ず reason（理由）と expires（期限）を明記し、期限切れ時に再判断する。
# 統括承認: 2026-07-21（コーディネーター経由）
#
# 2026-07-21: next を 15.5.20 / React 19 / vitest 4（vite 8 同梱）へメジャー更新し、
# 従来受容していた next の high 7件と ws の 1件は上流更新・override で解消・撤去した。
# 現在受容中の例外は下記 1 件のみ（next 15.5 系に修正が無い新規 high）。next 16 への
# 更新の別タスクで解消予定。
version: v1.5.0
ignore:
  SNYK-JS-NEXT-15105315:
    - '*':
        reason: 'next 15.5 系に修正なし（fix は 16.1.5 以降）。本アプリは静的 export（output:"export"）構成で悪用前提（PPR/cacheComponents・minimal mode）を満たさない。next 16 更新の別タスクで解消予定。'
        expires: 2027-01-21T00:00:00.000Z

# Snyk のスキャン対象から除外するパス（秘匿値・生成物・依存物・スキャン用 venv）。
exclude:
  global:
    - "**/.env*"
    - "**/cloud.env"
    - "frontend/out/**"
    - "**/node_modules/**"
    - "**/.venv*/**"
