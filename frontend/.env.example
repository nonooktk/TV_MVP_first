# frontend 環境変数のテンプレート（実値は .env.local / .env.production で設定）。
# NEXT_PUBLIC_* はビルド時に静的にバンドルへ埋め込まれる（＝公開値のみ）。

# FastAPIバックエンドのベースURL
NEXT_PUBLIC_API_BASE_URL=

# Agora App ID（通話基盤・委託コア①）
NEXT_PUBLIC_AGORA_APP_ID=

# Google OAuth クライアントID（家族側ログイン・公開値）。空なら Google 無効。
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Entra ID クライアントID（家族側ログイン・公開値）。空なら Microsoft 無効。
NEXT_PUBLIC_ENTRA_CLIENT_ID=

# 開発用の家族固定トークン（ローカル専用の裏口）。
# 【重要】認証プロバイダ有効時（Google/Entra）はこの値をバンドルへ焼き込まないため、
# 本番用 .env.production には決して書かない。ローカル開発の利便のためだけに .env.local に置く。
# 値は backend の DEV_FAMILY_TOKEN と一致させる（ローカル既定: dev-fixed-token）。
NEXT_PUBLIC_DEV_TOKEN=
