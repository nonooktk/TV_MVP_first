# backend の環境変数テンプレート。実値は .env にコピーして設定する（.env はコミット禁止）。
# 本番の秘密は Key Vault＋マネージドIDで管理する。ここには秘匿値を書かない。

# --- DB（ローカルは docker compose の postgres・ホストポート5433）---
# 例: postgresql://tvmvp:<password>@localhost:5433/tvmvp
DATABASE_URL=

# --- Azure Storage 接続文字列（ローカルは Azurite の well-known 接続文字列）---
AZURE_STORAGE_CONNECTION_STRING=

# --- Blob コンテナ名 ---
MEDIA_CONTAINER=media

# --- パイプライン用キュー名 ---
QUEUE_NAME=pipeline-jobs

# --- 家族側の固定 Bearer トークン（スタブ。将来 Entra に差し替え）---
DEV_FAMILY_TOKEN=

# --- フロントエンドのベースURL（登録リンク生成に使用）---
FRONTEND_BASE_URL=

AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

OPENAI_API_KEY=

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

GOOGLE_CLIENT_ID=

# --- 家族側ログイン クライアントID（公開値・空なら無効）---
ENTRA_CLIENT_ID=
